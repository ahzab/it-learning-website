# Price IDs from Stripe Dashboard
STRIPE_PRICE_BASIC="price_..."      # $7 one-time
STRIPE_PRICE_PRO="price_..."        # $15/month

# ================================
# EMAIL (Nodemailer / Resend)
# ================================
