// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────
// USER
// ─────────────────────────────────────
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  password         String?
  image            String?
  plan             Plan      @default(FREE)
  stripeCustomerId String?   @unique
  // AI usage tracking — resets monthly for PRO, lifetime for STARTER/FREE
  aiCreditsUsed    Int       @default(0)
  aiCreditsReset   DateTime? // next monthly reset date for PRO users
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  cvs          CV[]
  payments     Payment[]
  coverLetters CoverLetter[]
  jobSaves     JobSave[]
}

enum Plan {
  FREE // 3 AI credits, 1 CV, 2 templates, watermarked PDF
  STARTER // $4.99 one-time — 20 AI credits, 3 CVs, all templates, clean PDF
  PRO // $12/month — unlimited AI, unlimited CVs, Career Intelligence
}

// ─────────────────────────────────────
// NEXTAUTH
// ─────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────
// CV
// ─────────────────────────────────────
model CV {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("سيرتي الذاتية")
  language  Language @default(AR)
  template  String   @default("classic")
  country   String   @default("MA") // MA, AE, SA, EG, QA...
  isPublic  Boolean  @default(false)
  data      Json // All CV content stored as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Language {
  AR
  FR
  EN
}

// ─────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────
model Payment {
  id              String        @id @default(cuid())
  userId          String
  stripePaymentId String        @unique
  amount          Int // in cents
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  plan            Plan
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────
// JOB BOARD
// ─────────────────────────────────────
model JobSave {
  id      String   @id @default(cuid())
  userId  String
  jobId   String // deterministic ID from fetcher
  source  String
  title   String
  company String
  country String
  jobData String   @db.Text // full JobPosting JSON
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([savedAt])
}

// ─────────────────────────────────────
// COVER LETTER
// ─────────────────────────────────────
model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("خطاب تقديم")
  language  Language @default(AR)
  tone      String   @default("professional")
  content   String   @db.Text
  contentEn String?  @db.Text
  jobTitle  String?
  company   String?
  cvId      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────
// OBSERVABILITY
// ─────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  event      String // EventName from observability/index.ts
  userId     String?
  plan       String?
  ip         String?
  severity   String   @default("info") // info | warn | critical
  durationMs Int?
  meta       String?  @db.Text // JSON blob of extra data
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([severity, createdAt])
  @@index([createdAt])
}
